# Park Conscious Engine - Environment Template
# Copy this file to .env and fill in your real keys.

# MongoDB Connection
# Example: mongodb+srv://user:pass@cluster.mongodb.net/dbname
MONGODB_URI=

# JWT Authentication
# Random string for signing session cookies
JWT_SECRET=

# Razorpay Integration (Payments)
# Get these from https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Cloudinary Integration (Image Uploads)
# Get these from https://cloudinary.com/console
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google OAuth (Optional)
# Get this from Google Cloud Console
REACT_APP_GOOGLE_CLIENT_ID=

# Frontend Configuration
# Use http://localhost:3000 for local dev
REACT_APP_API_BASE_URL=https://events.parkconscious.in
